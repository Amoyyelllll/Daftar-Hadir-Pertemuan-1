<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Absensi & Patungan Zoom Pancasila</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #c0392b; /* Merah Marun/Pancasila */
            --accent: #2c3e50;
            --bg-gradient: linear-gradient(135deg, #c0392b 0%, #8e1a10 100%);
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: var(--bg-gradient);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 0;
            padding: 15px;
        }

        .card {
            background: white;
            width: 100%;
            max-width: 450px;
            padding: 35px;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.4);
        }

        /* Animasi Transisi Laman */
        .step { display: none; }
        .step.active { display: block; animation: slideIn 0.4s ease-out; }

        @keyframes slideIn { 
            from { opacity: 0; transform: translateX(20px); } 
            to { opacity: 1; transform: translateX(0); } 
        }

        .header { text-align: center; margin-bottom: 25px; }
        .header h2 { color: var(--primary); margin: 0; font-size: 1.4rem; border-bottom: 2px solid #eee; padding-bottom: 10px; }
        .header p { font-size: 0.85rem; color: #666; margin-top: 8px; line-height: 1.4; }

        .form-group { margin-bottom: 15px; }
        label { display: block; font-weight: 600; margin-bottom: 6px; color: var(--accent); font-size: 0.9rem; }
        
        input, select, textarea {
            width: 100%;
            padding: 12px;
            border: 1.5px solid #ddd;
            border-radius: 10px;
            box-sizing: border-box;
            font-family: inherit;
            font-size: 0.95rem;
        }

        input:focus, select:focus, textarea:focus { border-color: var(--primary); outline: none; background: #fffdfd; }

        /* Kotak Pembayaran */
        .payment-info {
            background: #fff5f5;
            border: 2px dashed var(--primary);
            padding: 20px;
            border-radius: 15px;
            margin: 20px 0;
            text-align: center;
        }

        .price { font-size: 1.8rem; font-weight: bold; color: var(--primary); display: block; margin: 5px 0; }
        .quote { font-style: italic; font-size: 0.85rem; color: #555; margin-bottom: 10px; }

        .btn-container { display: flex; gap: 10px; margin-top: 25px; }
        
        button {
            flex: 1;
            padding: 15px;
            border: none;
            border-radius: 12px;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn-next, .btn-submit { background: var(--primary); color: white; }
        .btn-prev { background: #f0f0f0; color: #555; }
        
        button:hover:not(:disabled) { opacity: 0.9; transform: translateY(-2px); }
        button:disabled { background: #ccc; cursor: not-allowed; }

        .required { color: var(--primary); }

        /* Loading Overlay */
        #loading {
            display: none;
            text-align: center;
            color: var(--primary);
            font-weight: bold;
            margin-top: 10px;
        }
    </style>
</head>
<body>

<div class="card">
    <form id="pancasilaForm">
        
        <div class="step active" id="step1">
            <div class="header">
                <h2>Daftar Hadir Pendidikan Pancasila</h2>
                <p>Selasa (13.00-14.50)<br><strong>Dosen:</strong> Prof. DR. Ciek Julyati Hisyam, M.M., M,Si</p>
            </div>

            <div class="form-group">
                <label>Nama Lengkap <span class="required">*</span></label>
                <input type="text" name="Nama Lengkap" placeholder="Input Nama Lengkap" required>
            </div>

            <div class="form-group">
                <label>NIM <span class="required">*</span></label>
                <input type="text" name="NIM" placeholder="Masukkan NIM Anda" required>
            </div>

            <div class="form-group">
                <label>Program Studi <span class="required">*</span></label>
                <input type="text" name="Prodi" placeholder="Contoh: S1 Sosiologi" required>
            </div>

            <div class="form-group">
                <label>Keterangan Absen <span class="required">*</span></label>
                <select name="Status" id="status" required>
                    <option value="">-- Pilih Status --</option>
                    <option value="Hadir">Hadir</option>
                    <option value="Izin">Izin</option>
                    <option value="Sakit">Sakit</option>
                </select>
            </div>

            <div class="form-group">
                <label>Alasan (Wajib jika Izin/Sakit)</label>
                <textarea name="Alasan" id="alasan" rows="2" placeholder="Tulis alasan jika tidak hadir..."></textarea>
            </div>

            <div class="form-group">
                <label>Bukti Hadir <span class="required">*</span></label>
                <input type="file" name="Bukti Hadir" id="fileHadir" accept="image/*" required>
            </div>

            <button type="button" class="btn-next" onclick="validateStep1()">Lanjut ke Pembayaran ➔</button>
        </div>

        <div class="step" id="step2">
            <div class="header">
                <h2>Iuran Kuliah (Patungan Zoom)</h2>
                <p>Implementasi nilai gotong royong dalam perkuliahan daring.</p>
            </div>

            <div class="payment-info">
                <p class="quote">"Pembayaran seharga 20.000 dibagi 50 mahasiswa"</p>
                <p style="margin:0; font-size: 0.9rem;">Nominal per Mahasiswa:</p>
                <span class="price">Rp400</span>
                <hr style="border: 0.5px solid #ffcccc; margin: 15px 0;">
                <p><strong>Transfer via Dana/Gopay:</strong><br>
                <span style="font-size: 1.2rem; letter-spacing: 1px; color: #000;">085714086426</span></p>
            </div>

            <div class="form-group">
                <label>Unggah Bukti Pembayaran <span class="required">*</span></label>
                <input type="file" name="Bukti Bayar" id="fileBayar" accept="image/*" required>
            </div>

            <div id="loading">Sedang mengirim data... Mohon tunggu.</div>

            <div class="btn-container">
                <button type="button" class="btn-prev" onclick="goToStep(1)">Kembali</button>
                <button type="submit" id="submitBtn" class="btn-submit">Kirim Sekarang</button>
            </div>
        </div>
    </form>
</div>

<script>
    // Link Google Apps Script kamu
    const scriptURL = 'https://script.google.com/macros/s/AKfycbxh0XpeYJ4feDkvI0HoOc8R7ve8sPXubQTV71ABecWtSftxx4ENqoYObylAoN5-S-RB/exec';
    const form = document.getElementById('pancasilaForm');
    const loadingTxt = document.getElementById('loading');
    const submitBtn = document.getElementById('submitBtn');

    // Navigasi Laman
    function goToStep(stepNumber) {
        document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
        document.getElementById('step' + stepNumber).classList.add('active');
    }

    // Validasi Laman 1
    function validateStep1() {
        const requiredFields = document.getElementById('step1').querySelectorAll('input[required], select[required]');
        let allValid = true;

        requiredFields.forEach(field => {
            if (!field.value) {
                allValid = false;
                field.style.borderColor = "red";
            } else {
                field.style.borderColor = "#ddd";
            }
        });

        // Logika tambahan: Alasan wajib jika tidak Hadir
        const status = document.getElementById('status').value;
        const alasan = document.getElementById('alasan');
        if ((status === 'Izin' || status === 'Sakit') && !alasan.value) {
            allValid = false;
            alasan.style.borderColor = "red";
            alert("Mohon sertakan alasan ketidakhadiran Anda.");
            return;
        }

        if (allValid) {
            goToStep(2);
        } else {
            alert("Pastikan semua kolom bertanda merah sudah diisi/unggah.");
        }
    }

    // Proses Submit ke Google Sheets
    form.addEventListener('submit', e => {
        e.preventDefault();
        
        // Cek file bukti bayar di laman 2
        if (!document.getElementById('fileBayar').value) {
            alert("Harap unggah bukti pembayaran terlebih dahulu.");
            return;
        }

        submitBtn.disabled = true;
        loadingTxt.style.display = "block";
        submitBtn.innerHTML = "Proses...";

        fetch(scriptURL, { 
            method: 'POST', 
            body: new FormData(form)
        })
        .then(response => {
            alert('Sukses! Data Absensi dan Bukti Pembayaran Anda telah masuk ke Excel. Terima kasih!');
            form.reset();
            location.reload(); // Refresh untuk keamanan data
        })
        .catch(error => {
            alert('Terjadi kesalahan saat mengirim data. Silakan coba lagi.');
            console.error('Error!', error.message);
            submitBtn.disabled = false;
            loadingTxt.style.display = "none";
            submitBtn.innerHTML = "Kirim Sekarang";
        });
    });
</script>

</body>
</html>
